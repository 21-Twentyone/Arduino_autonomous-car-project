Objetivo

Implementar un sistema de navegación autónoma que permita al coche seguir una línea en el suelo mediante el uso de un sensor infrarrojo.

⚙️ Concepto de funcionamiento

El módulo de seguimiento de línea utiliza un sensor IR para detectar diferencias de color basadas en la reflexión:

Superficie oscura (negra) → absorbe luz → detectada como línea
Superficie clara (blanca) → refleja luz → detectada como fondo

El Arduino lee constantemente este valor y ajusta el movimiento del coche en tiempo real.

Lá lógica detras del functionamiento es que el arduino hace que el motor siga una linea y tambien realiza pequeños giros(ajustes) cuando es necesario para volver a la linea.

##nueva material usado: Sensor de linea basado de Infrarojo

##código
#include <EEPROM.h>

const int a1 = 6; 
const int a2 = 5;
const int b1A = 10;
const int b2A = 9;

const int line_track_left = 4;
const int line_track_right = 13;

int speed = 150;
int turn_speed = 150;
float leftOffset=1.0;
float rightOffset=1.0;      

void moveforward() {
  analogWrite(a1, int(speed*rightOffset));
  analogWrite(b2A, int(speed*leftOffset));
  digitalWrite(a2, 0);
  digitalWrite(b1A, 0);
}
void turn_left() {

  analogWrite(a1, turn_speed);
  analogWrite(a2, 0);
  analogWrite(b1A, 0);
  analogWrite(b2A, 0);
}
void turn_right() {
  analogWrite(b2A, turn_speed);
  analogWrite(a1, 0);
  analogWrite(a2, 0);
}
void stop_move(){
  analogWrite(a1, 0);
  analogWrite(a2, 0);
  analogWrite(b1A, 0);
  analogWrite(b2A, 0);
}

void moveBackward(){
  analogWrite(a2,speed);
  digitalWrite(a1,0);
  analogWrite(b1A,speed);
  digitalWrite(b2A,0);
}


void setup() {
  Serial.begin(9600);
  pinMode(a1, OUTPUT);
  pinMode(a2, OUTPUT); 
  pinMode(b1A, OUTPUT);
  pinMode(b2A, OUTPUT);
  EEPROM.write(0, 80); //write the offset to the left motor
  EEPROM.write(1, 93); //write the offset to the right motor
  leftOffset = EEPROM.read(0) * 0.01; //read the offset
  rightOffset = EEPROM.read(1) * 0.01;//read the offset
}

void loop() {
  int left  = digitalRead(line_track_left);
  int right = digitalRead(line_track_right);
  Serial.print("Left:");Serial.println(left); Serial.print("Right"); Serial.println(right);

  if ( left == 1) {
  turn_right();
  }else{
    turn_left();
  }
}

