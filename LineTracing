Objetivo

Implementar un sistema de navegación autónoma que permita al coche seguir una línea en el suelo mediante el uso de un sensor infrarrojo.

⚙️ Concepto de funcionamiento

El módulo de seguimiento de línea utiliza un sensor IR para detectar diferencias de color basadas en la reflexión:

Superficie oscura (negra) → absorbe luz → detectada como línea
Superficie clara (blanca) → refleja luz → detectada como fondo

El Arduino lee constantemente este valor y ajusta el movimiento del coche en tiempo real.

Lá lógica detras del functionamiento es que el arduino hace que el motor siga una linea y tambien realiza pequeños giros(ajustes) cuando es necesario para volver a la linea.

##nueva material usado: Sensor de linea basado de Infrarojo

##código
const int a1 = 6; 
const int a2 = 5;
const int b1A = 10;
const int b2A = 9;

const int line_track_left = 4;
const int line_track_right = 13;

int speed = 120;
int turn_speed = 90;
int boost=170;
int boost_duration=20;

int last_position = 0;
int last_action = -1; // tracks what the car was doing last iteration


void moveforward() {
  analogWrite(a1,boost-10);
  analogWrite(b2A,boost);
  delay(boost_duration);
  //gives an initial boost to the wheels
  analogWrite(a1, speed-10);
  analogWrite(b2A, speed);
  digitalWrite(a2, 0);
  digitalWrite(b1A, 0);
}
void turn_left() {
  analogWrite(a1,boost);
  delay(boost_duration);

  analogWrite(a1, turn_speed);
  analogWrite(a2, 0);
  analogWrite(b1A, 0);
  analogWrite(b2A, 0);
}
void turn_right() {
  analogWrite(b1A, 0);
  analogWrite(b2A,boost);
  delay(boost_duration);

  analogWrite(b2A, turn_speed);
  analogWrite(a1, 0);
  analogWrite(a2, 0);
}
void stop_move() {
  analogWrite(a1, 0);
  analogWrite(a2, 0);
  analogWrite(b1A, 0);
  analogWrite(b2A, 0);
}

void setup() {
  Serial.begin(9600);
  pinMode(a1, OUTPUT);
  pinMode(a2, OUTPUT); 
  pinMode(b1A, OUTPUT);
  pinMode(b2A, OUTPUT);
  pinMode(line_track_left, INPUT);
  pinMode(line_track_right, INPUT);
}

void loop() {
  int left = digitalRead(line_track_left);
  int right = digitalRead(line_track_right);

  Serial.print("L: ");
  Serial.print(left);
  Serial.print(" | R: ");
  Serial.println(right);

  if (left == 1 && right == 1) {
    moveforward();
  }
  else if (left == 0 && right == 1) {
    turn_left();
    last_position = -1;
  }
  else if (left == 1 && right == 0) {
    turn_right();
    last_position = 1;
  }
  else if (left == 0 && right == 0) {
    if (last_position == -1) {
      turn_left();
    } else if (last_position == 1) {
      turn_right();
    } else {
      stop_move();
    }
  }
  delay(10);
}

