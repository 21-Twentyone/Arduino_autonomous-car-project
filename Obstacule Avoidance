En esta fase se integra un sensor ultrasónico HC-SR04 al sistema de navegación del robot. Este sensor permite medir la distancia a obstáculos frontales mediante ondas de sonido, lo que añade una capa de percepción del entorno que antes no existía.

El comportamiento del robot pasa a ser reactivo e híbrido: los sensores IR siguen guiando la dirección general, pero el ultrasonido tiene prioridad cuando detecta objetos cercanos en la parte frontal. En ese caso, el sistema interrumpe el movimiento normal, ejecuta una secuencia de seguridad (parar → retroceder → girar) y luego continúa la navegación.

Esto mejora significativamente la seguridad del robot, evitando colisiones directas y permitiendo una navegación más autónoma en entornos desconocidos.

Objetivos
-Detectar obstáculos frontales
-Detener y evitar colisiones
-Mantener navegación con sensores IR

Hardware
-Arduino Uno
-Driver de motores (L298N)
-2 motores DC
-HC-SR04
-Sensores IR (izq/der)

Lógica de evitación
Si hay obstáculo cerca:
-Parar
-Retroceder
-Girar

Código
#include <EEPROM.h>

const int a1 = 6;
const int a2 = 5;
const int b1A = 10;
const int b2A = 9;
const int linetrack=2;
const int ir_right=7;
const int ir_left=8;
const int trigpin=A0;
const int echopin=A1;
const int stopDistance=15;

int speed = 150;
int turn_speed = 150;

float leftOffset=1.0;
float rightOffset=1.0;      

long readDist(){
  digitalWrite(trigpin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigpin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigpin, LOW);

  long duration = pulseIn(echopin, HIGH, 5000); // timeout added
  long distance = duration * 0.034 / 2;

  return distance;
}

void moveforward() {
  analogWrite(a1, int(speed*rightOffset));
  analogWrite(b2A, int(speed*leftOffset));
  digitalWrite(a2, 0);
  digitalWrite(b1A, 0);
}
void turn_left() {

  analogWrite(a1, turn_speed);
  analogWrite(a2, 0);
  analogWrite(b1A, 0);
  analogWrite(b2A, 0);
}
void turn_right() {
  analogWrite(b2A, turn_speed);
  analogWrite(a1, 0);
  analogWrite(a2, 0);
}
void stop_move(){
  analogWrite(a1, 0);
  analogWrite(a2, 0);
  analogWrite(b1A, 0);
  analogWrite(b2A, 0);
}

void moveBackward(){
  analogWrite(a2,speed);
  digitalWrite(a1,0);
  analogWrite(b1A,speed);
  digitalWrite(b2A,0);
}


void setup() {
  Serial.begin(9600);
  pinMode(a1, OUTPUT);
  pinMode(a2, OUTPUT); 
  pinMode(b1A, OUTPUT);
  pinMode(b2A, OUTPUT);
  pinMode(linetrack,INPUT);
  pinMode(ir_right,INPUT);
  pinMode(ir_left,INPUT);
  pinMode(echopin,INPUT);
  pinMode(trigpin,OUTPUT);
  EEPROM.write(0, 80); //write the offset to the left motor
  EEPROM.write(1, 93); //write the offset to the right motor
  leftOffset = EEPROM.read(0) * 0.01; //read the offset
  rightOffset = EEPROM.read(1) * 0.01;//read the offset
}

void loop() {
int left = digitalRead(ir_left);
int right = digitalRead(ir_right);
long distance = readDist();
Serial.println(distance);

if (distance > 0 && distance < stopDistance) {

moveBackward();
delay(200);

if (right && !left){
  turn_right();
} 
else{
  turn_left();
}
return;
}

if (right && !left){
  turn_right();
} 
else if (left && !right){
  turn_left();
} 
else {
  moveforward();
}
}






